@model IEnumerable<Trainer>
@{ ViewData["Title"] = "Trainers"; }
<div class="container"><header class="d-flex justify-content-between mt-5 mb-4 align-items-center"><div><h2 class="text-primary-color mb-0">Our Trainers</h2><p class="text-muted">Professional fitness instructors</p></div><a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3">Add Trainer</a></header>
@if (Model.Any()) { <div class="table-responsive"><table class="table table-borderless"><thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Specialization</th><th>Action</th></tr></thead><tbody>@foreach(var trainer in Model){<tr><td>@trainer.Name</td><td>@trainer.Email</td><td>@trainer.Phone</td><td><span class="badge bg-primary">@trainer.Specialties</span></td><td><a asp-action="Details" asp-route-id="@trainer.Id">Details</a> | <a asp-action="Edit" asp-route-id="@trainer.Id">Edit</a> | <a asp-action="Delete" asp-route-id="@trainer.Id" class="text-danger">Delete</a></td></tr>}</tbody></table></div> } else { <div class="text-center py-5"><h4 class="text-muted">No Trainers Available</h4></div> }</div>
