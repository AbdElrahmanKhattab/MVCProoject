@model TrainerFormViewModel

@{
    ViewData["Title"] = "Edit Trainer";
}

<section class="my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-primary-color fw-bold mb-1">Trainer Module</p>
            <h1 class="fw-bolder text-black-alternative">Edit @Model.Name</h1>
        </div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill">Cancel</a>
    </div>

    <partial name="_TrainerForm" model="Model" />
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
