@model Trainer
@{ ViewData["Title"] = "Trainer Details"; }
<div class="container mt-5"><div class="card p-4 shadow-sm"><h2 class="text-primary-color">@Model.Name</h2><p><strong>Email:</strong> @Model.Email</p><p><strong>Phone:</strong> @Model.Phone</p><p><strong>Specialization:</strong> @Model.Specialties</p><a asp-action="Index" class="btn btn-fill">Back to List</a></div></div>
