@model IEnumerable<GymSession>
@{ ViewData["Title"] = "Sessions"; }
<div class="container"><header class="d-flex justify-content-between mt-5 mb-4 align-items-center"><div><h2 class="text-primary-color mb-0">Training Sessions</h2><p class="text-muted">Manage gym training sessions</p></div><a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3">Add Session</a></header>@if(Model.Any()){<div class="row g-4">@foreach(var s in Model){<div class="col-md-4"><div class="card h-100 shadow-sm"><div class="card-header bg-primary text-white"><h5>@s.CategoryName</h5></div><div class="card-body"><p>@s.Description</p><p><strong>Trainer:</strong> @s.TrainerName</p><p><strong>Time:</strong> @s.StartDate - @s.EndDate</p><p><strong>Capacity:</strong> @(s.Capacity - s.Bookings.Count) / @s.Capacity</p></div><div class="card-footer"><a asp-action="Details" asp-route-id="@s.Id">Details</a> | <a asp-action="Edit" asp-route-id="@s.Id">Edit</a> | <a asp-action="Delete" asp-route-id="@s.Id" class="text-danger">Delete</a></div></div></div>}</div>}else{<div class="text-center py-5"><h4 class="text-muted">No Sessions Available</h4></div>}</div>
