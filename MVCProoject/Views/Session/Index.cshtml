@model IEnumerable<MVC.ViewModels.SessionViewModel>

@{
    ViewData["Title"] = "Sessions";
}

@await Html.PartialAsync("_AlertMessages")

<section class="sessions-page my-5">
    <header class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <p class="text-primary-color fw-bold mb-2">Training Schedule</p>
            <h1 class="fw-bolder display-5 text-black-alternative mb-0">Manage training sessions</h1>
        </div>
        <a asp-action="Create" class="btn btn-fill fw-medium rounded-pill px-4 py-3">
            <i class="bi bi-plus-lg me-2"></i>Add Session
        </a>
    </header>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h2 class="h4 mt-3 text-muted">No Sessions Available</h2>
            <p class="text-muted">Create your first training session to get started.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var session in Model)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card h-100 shadow-sm border-0 session-card">
                        <div class="card-header text-white py-3 @(session.Status == "Ongoing" ? "bg-success" : session.Status == "Upcoming" ? "bg-primary" : "bg-secondary")">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                                <h2 class="h5 mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>@session.CategoryName
                                </h2>
                                <span class="badge bg-light text-dark">@session.Status</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3">@session.Description</p>

                            <div class="session-info mb-3">
                                <div class="info-item mb-2">
                                    <i class="bi bi-person-circle text-primary-color me-2"></i>
                                    <strong>Trainer:</strong> @session.TrainerName
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-calendar3 text-primary-color me-2"></i>
                                    <strong>Date:</strong> @session.DateDisplay
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-clock text-primary-color me-2"></i>
                                    <strong>Time:</strong> @session.TimeRangeDisplay
                                </div>
                                <div class="info-item mb-2">
                                    <i class="bi bi-hourglass-split text-primary-color me-2"></i>
                                    <strong>Duration:</strong> @session.DurationDisplay
                                </div>
                                <div class="info-item">
                                    <i class="bi bi-people text-primary-color me-2"></i>
                                    <strong>Available:</strong> @session.AvailableSlots / @session.Capacity slots
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@session.Id" class="btn btn-outline btn-sm">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                                <div class="d-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@session.Id" class="btn btn-outline btn-sm flex-fill @(session.Status == "Upcoming" ? "" : "disabled")">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@session.Id" class="btn btn-outline text-danger btn-sm flex-fill">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>
