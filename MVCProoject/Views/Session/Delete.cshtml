@model MVC.ViewModels.SessionViewModel

@{
    ViewData["Title"] = "Delete Session";
}

<section class="session-delete my-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <article class="card shadow-lg border-0 text-center">
                <div class="card-body p-5">
                    <i class="bi bi-exclamation-triangle-fill text-warning display-1 mb-4"></i>
                    <h1 class="h3 text-primary-color mb-3">Delete Session</h1>

                    <div class="alert alert-warning text-start mb-4">
                        <strong><i class="bi bi-info-circle me-2"></i>Warning:</strong>
                        This action cannot be undone. All bookings for this session will also be deleted.
                    </div>

                    <dl class="text-start border rounded p-3 mb-4">
                        <dt>Category</dt>
                        <dd>@Model.CategoryName</dd>
                        <dt>Trainer</dt>
                        <dd>@Model.TrainerName</dd>
                        <dt>Time</dt>
                        <dd>@Model.StartDate.ToString("MMM dd, yyyy hh:mm tt") - @Model.EndDate.ToString("hh:mm tt")</dd>
                    </dl>

                    <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                        <div class="d-flex justify-content-between gap-3">
                            <a asp-action="Index" class="btn btn-outline flex-fill">
                                <i class="bi bi-x-lg me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger flex-fill">
                                <i class="bi bi-trash me-1"></i>Delete
                            </button>
                        </div>
                    </form>
                </div>
            </article>
        </div>
    </div>
</section>
