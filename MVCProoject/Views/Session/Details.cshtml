@model GymSession
@{ ViewData["Title"] = "Session Details"; }
<div class="container mt-5"><div class="card p-4 shadow-sm"><h2>@Model.CategoryName</h2><p>@Model.Description</p><p><strong>Trainer:</strong> @Model.TrainerName</p><p><strong>Capacity:</strong> @Model.Capacity</p><p><strong>Start:</strong> @Model.StartDate</p><p><strong>End:</strong> @Model.EndDate</p><a asp-action="Index" class="btn btn-fill">Back to List</a></div></div>
