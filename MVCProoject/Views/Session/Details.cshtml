@model MVC.ViewModels.SessionViewModel

@{
    ViewData["Title"] = "Session Details";
}

<section class="session-details my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <article class="card shadow-lg border-0">
                <div class="card-header @(Model.Status == "Ongoing" ? "bg-success" : Model.Status == "Upcoming" ? "bg-primary" : "bg-secondary") text-white text-center py-4">
                    <i class="bi bi-calendar-event display-4 mb-3"></i>
                    <h1 class="h2 mb-2">@Model.CategoryName</h1>
                    <span class="badge bg-light text-dark fs-6">@Model.Status</span>
                </div>

                <div class="card-body p-4">
                    <div class="mb-4 p-3 bg-light rounded">
                        <h2 class="h6 text-primary-color mb-2">
                            <i class="bi bi-file-text me-2"></i>Description
                        </h2>
                        <p class="mb-0">@Model.Description</p>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 border rounded">
                                <small class="text-muted d-block">Trainer</small>
                                <strong>@Model.TrainerName</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded">
                                <small class="text-muted d-block">Capacity</small>
                                <strong>@Model.AvailableSlots / @Model.Capacity spots available</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded">
                                <small class="text-muted d-block">Start Time</small>
                                <strong>@Model.StartDate.ToString("MMM dd, yyyy hh:mm tt")</strong>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded">
                                <small class="text-muted d-block">End Time</small>
                                <strong>@Model.EndDate.ToString("MMM dd, yyyy hh:mm tt")</strong>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 border rounded bg-light">
                                <small class="text-muted d-block">Duration</small>
                                <strong class="text-primary-color fs-5">@Model.DurationDisplay</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                        <a asp-action="Index" class="btn btn-outline flex-fill">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                        @if (Model.Status == "Upcoming")
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-fill flex-fill">
                                <i class="bi bi-pencil me-1"></i>Edit Session
                            </a>
                        }
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>
