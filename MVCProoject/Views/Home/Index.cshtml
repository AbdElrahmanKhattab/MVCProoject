@model MVC.ViewModels.AnalyticsViewModel

@{
    ViewData["Title"] = "Home";
}

<section class="home-section my-4">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <header class="text-black-alternative">
                <h1 class="fw-bolder display-2 mb-4">
                    Your body can
                    <span class="text-primary-color">stand almost</span> anything
                </h1>

                <p class="mb-6">
                    It's your mind that needs convincing. Push past your limits,
                    stay committed, and watch your body transform into a
                    powerhouse of strength and resilience.
                </p>
            </header>

            <div class="stats-bar">
                <div class="row g-0">
                    <div class="col-4">
                        <div class="stat">
                            <span class="fw-bolder fs-5 d-block mb-1">@Model.TotalMembers</span>
                            <h2 class="fs-5 fw-normal">Total Members</h2>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat">
                            <span class="fw-bolder fs-5 d-block mb-1">@Model.ActiveMembers</span>
                            <h2 class="fs-5 fw-normal">Active Members</h2>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat">
                            <span class="fw-bolder fs-5 d-block mb-1">@Model.TotalTrainers</span>
                            <h2 class="fs-5 fw-normal">Trainers</h2>
                        </div>
                    </div>
                </div>
                <div class="row g-0">
                    <div class="col-4">
                        <div class="stat">
                            <span class="fw-bolder fs-5 d-block mb-1">@Model.UpcomingSessions</span>
                            <h2 class="fs-5 fw-normal">Upcoming Sessions</h2>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat">
                            <span class="fw-bolder fs-5 d-block mb-1">@Model.OngoingSessions</span>
                            <h2 class="fs-5 fw-normal">Ongoing Sessions</h2>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat">
                            <span class="fw-bolder fs-5 d-block mb-1">@Model.CompletedSessions</span>
                            <h2 class="fs-5 fw-normal">Completed Sessions</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="buttons my-4">
                <a asp-controller="Plan" asp-action="Index" class="get-started bg-primary-color text-white btn rounded-5 fw-medium px-3 py-2 me-3 border-2 border-primary-color">
                    View Plans
                </a>
                <a asp-controller="Session" asp-action="Index" class="explore-more border-primary-color btn rounded-5 fw-medium px-3 py-2 border-2 text-primary-color">
                    Explore Sessions
                </a>
            </div>
        </div>

        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="d-flex justify-content-center">
                <img src="~/images/Theo Vance.jpg" alt="Fitness member" class="img-fluid rounded-4 shadow" />
            </div>
        </div>
    </div>
</section>

<section class="about my-5 text-black-alternative">
    <div class="container">
        <div class="row g-5 justify-content-center">
            <div class="col-12 col-lg-6 w-50 w-md-100">
                <div class="characters position-relative">
                    <div class="image">
                        <img src="~/images/about p1.jpg" alt="Gym member" />
                    </div>
                    <div class="image position-absolute d-none d-lg-block">
                        <img src="~/images/about p2.jpg" alt="Gym member" />
                    </div>
                    <div class="image position-absolute d-none d-lg-block">
                        <img src="~/images/about p3.jpg" alt="Gym member" />
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="title d-flex justify-content-start align-items-start gap-2">
                    <img src="~/images/dumbbell.jpg" alt="dumbbell icon" />
                    <h2 class="text-primary-color fs-5">About Us</h2>
                </div>

                <header>
                    <p class="fw-bolder display-6 mb-4">
                        EMPOWERING YOU TO ACHIEVE
                        <span class="text-primary-color">YOUR FITNESS</span> GOALS
                    </p>
                    <p class="text">
                        We believe fitness is more than just a workout, it is a lifestyle.
                        With top-of-the-line facilities, certified trainers, and a supportive
                        community, we are here to guide every step.
                    </p>
                </header>
            </div>
        </div>
    </div>
</section>

<section class="workout">
    <div class="container">
        <div class="title">
            <h2>WORKOUTS</h2>
            <p class="text-white fw-bolder fs-2 mb-4">
                Transform Your Body with Our Dynamic Upcoming Workouts
            </p>
        </div>

        <div class="row row-cols-md-3 row-cols-1 gy-4 gx-2 gx-md-4">
            <div>
                <div class="card">
                    <img src="~/images/workout 1.jpg" class="card-img-top" alt="Group workout" />
                    <footer class="card-footer bg-white">
                        <h3 class="card-title text-black-alternative text-uppercase fw-bolder h5">Group Workout</h3>
                        <a asp-controller="Session" asp-action="Index">Explore</a>
                    </footer>
                </div>
            </div>
            <div>
                <div class="card">
                    <img src="~/images/workout 2.jpg" class="card-img-top" alt="Strength workout" />
                    <footer class="card-footer bg-white">
                        <h3 class="card-title text-black-alternative text-uppercase fw-bolder h5">Strength Training</h3>
                        <a asp-controller="Session" asp-action="Index">Explore</a>
                    </footer>
                </div>
            </div>
            <div>
                <div class="card">
                    <img src="~/images/workout 3.jpg" class="card-img-top" alt="Personal training" />
                    <footer class="card-footer bg-white">
                        <h3 class="card-title text-black-alternative text-uppercase fw-bolder h5">Personal Training</h3>
                        <a asp-controller="Session" asp-action="Index">Explore</a>
                    </footer>
                </div>
            </div>
        </div>
    </div>
</section>
