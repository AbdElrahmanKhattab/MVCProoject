@model SessionBookingsViewModel

@{
    ViewData["Title"] = "Upcoming Session Members";
}

<partial name="_AlertMessages" />

<header class="bg-primary text-white rounded-3 p-4 shadow-sm mt-5 mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1 fw-semibold">Session Members</h1>
            <p class="mb-0 text-light opacity-75">Members That Already Book Session</p>
        </div>
        <div class="text-end">
            <a asp-action="Create" asp-route-sessionId="@Model.Session.Id" class="btn btn-light">
                <i class="bi bi-plus-lg me-1"></i> New Booking
            </a>
        </div>
    </div>
</header>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model.Bookings.Any())
        {
            <table class="table table-striped table-hover align-middle text-center">
                <thead>
                    <tr>
                        <th>Member</th>
                        <th>Booking Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Bookings)
                    {
                        <tr>
                            <td>@booking.Member.Name</td>
                            <td>@booking.BookingDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                            <td>
                                <div class="d-flex justify-content-center gap-1">
                                    <form asp-action="Cancel" method="post" class="m-0">
                                        <input type="hidden" name="id" value="@booking.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to cancel this booking?');">
                                            <i class="bi bi-x-lg"></i> Cancel
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-person-workspace display-1 text-muted"></i>
                <h2 class="h4 mt-3 text-muted">No Bookings Available</h2>
                <p class="text-muted">Add your first booking to get started</p>
            </div>
        }
    </div>

    <div class="card-footer bg-white">
        <a asp-action="Index" class="btn btn-fill">Back to List</a>
    </div>
</div>
