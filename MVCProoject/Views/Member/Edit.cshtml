@model MemberToUpdateViewModel

@{
    ViewData["Title"] = "Edit Member";
}

<section class="my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-primary-color fw-bold mb-1">Member Module</p>
            <h1 class="fw-bolder text-black-alternative">Edit @Model.Name</h1>
        </div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill">Cancel</a>
    </div>

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="bg-white border rounded-4 p-4 shadow-sm">
        <input asp-for="Id" type="hidden" />
        <input asp-for="Name" type="hidden" />
        <input asp-for="Photo" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="alert alert-info">Name and photo are locked for this update task.</div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Email" class="form-label fw-bold"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Phone" class="form-label fw-bold"></label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="BuildingNumber" class="form-label fw-bold">Building</label>
                <input asp-for="BuildingNumber" class="form-control" />
                <span asp-validation-for="BuildingNumber" class="text-danger"></span>
            </div>
            <div class="col-md-5">
                <label asp-for="Street" class="form-label fw-bold"></label>
                <input asp-for="Street" class="form-control" />
                <span asp-validation-for="Street" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="City" class="form-label fw-bold"></label>
                <input asp-for="City" class="form-control" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary rounded-pill px-4 mt-4">Save Changes</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
