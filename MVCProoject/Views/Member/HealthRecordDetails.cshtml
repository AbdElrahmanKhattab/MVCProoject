@model Member

@{
    ViewData["Title"] = $"{Model.Name} Health Record";
    var record = Model.HealthRecord;
}

<section class="my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-primary-color fw-bold mb-1">Health Record</p>
            <h1 class="fw-bolder text-black-alternative">@Model.Name</h1>
        </div>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill">Back</a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            <div class="bg-white border rounded-4 p-4 shadow-sm h-100">
                <p class="text-muted mb-1">Height</p>
                <h2 class="fw-bold">@record.Height cm</h2>
            </div>
        </div>
        <div class="col">
            <div class="bg-white border rounded-4 p-4 shadow-sm h-100">
                <p class="text-muted mb-1">Weight</p>
                <h2 class="fw-bold">@record.Weight kg</h2>
            </div>
        </div>
        <div class="col">
            <div class="bg-white border rounded-4 p-4 shadow-sm h-100">
                <p class="text-muted mb-1">Blood Type</p>
                <h2 class="fw-bold">@record.BloodType</h2>
            </div>
        </div>
    </div>

    <div class="bg-white border rounded-4 p-4 shadow-sm mt-4">
        <p class="text-muted mb-1">Note</p>
        <p class="fs-5 mb-3">@(string.IsNullOrWhiteSpace(record.Note) ? "No notes recorded." : record.Note)</p>
        <p class="text-muted mb-0">Last update: @record.LastUpdate.ToString("MMM dd, yyyy")</p>
    </div>
</section>
