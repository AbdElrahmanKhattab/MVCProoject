@model Member

@{
    ViewData["Title"] = "Delete Member";
}

<section class="my-5">
    <div class="bg-white border rounded-4 p-4 shadow-sm">
        <p class="text-danger fw-bold mb-1">Delete Member</p>
        <h1 class="fw-bolder text-black-alternative">Delete @Model.Name?</h1>
        <p class="text-muted">This will permanently remove the member and their health record.</p>

        <dl class="row">
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Phone</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
            <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
        </form>
    </div>
</section>
